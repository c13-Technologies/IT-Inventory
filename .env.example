# .env.example — copy to .env and fill in real values
#   cp .env.example .env
#
# NEVER commit the real .env (it's in .gitignore). All values below are
# placeholders; replace them with values from your local setup / secret store.

# ============================================================================
# Database — used by both the Node app (DATABASE_URL) and docker-compose
# (POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB). Keep them in sync.
# ============================================================================

# Connection string the Prisma client and server.js read.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/inventory_dev?schema=public"

# The three values below are read by docker-compose.yml when starting the
# dev Postgres container. They must match the user/password/dbname in
# DATABASE_URL above, or the app can't reach the DB.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory_dev

# ============================================================================
# Auth
# ============================================================================

# 32+ char random string for signing JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-32-char-random-string

# ============================================================================
# Webhooks
# ============================================================================

# 32-byte AES-256-GCM key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
WEBHOOK_ENCRYPTION_KEY=base64-encoded-32-byte-aes-256-gcm-key

# ============================================================================
# Optional integrations
# ============================================================================

# Resend (outbound email). Get a key at https://resend.com
RESEND_API_KEY=

# ============================================================================
# Server
# ============================================================================

# Auto-falls back to 3001, 3002, ... if 3000 is busy (up to 10 ports).
PORT=3000

# Set to 0.0.0.0 to expose on the LAN (dev only).
HOST=127.0.0.1

# Set to "production" in prod.
NODE_ENV=development
