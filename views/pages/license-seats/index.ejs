<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',       href: '/' },
                    { label: 'Inventory',  href: '/license-seats' },
                    { label: 'License Seats', href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <%- include('../../partials/filter-toolbar', { filters: ['search'], query: query, action: '/license-seats', resetUrl: '/license-seats', searchPlaceholder: 'License name, asset, or user…' }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'License Seat', total: seats.length, newUrl: '/license-seats/new', newLabel: 'Assign Seat' }) %>

                  <% if (seats.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-checkbox-checked', title: 'No license seats assigned', message: 'Assign software license seats to users or assets to track utilization.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>License</th>
                            <th>Asset</th>
                            <th>User</th>
                            <th>Assigned</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% seats.forEach(function(s) { %>
                            <tr>
                              <td><strong><%= s.licenseName || '—' %></strong></td>
                              <td><%= s.assetName || '—' %></td>
                              <td><%= s.userName || '—' %></td>
                              <td><%= s.assignedAt ? new Date(s.assignedAt).toLocaleDateString() : '—' %></td>
                              <td class="text-end"><%- include('../../partials/row-actions', { slug: 'license-seats', id: s.id, capLc: 'licenseSeat' }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
