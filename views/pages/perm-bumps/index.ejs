<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',  href: '/' },
                    { label: 'Admin', href: '/perm-bumps' },
                    { label: 'Permission Bumps', href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <div class="d-flex align-items-start mb-3">
                    <div class="flex-grow-1">
                      <h5 class="card-title mb-1">Session invalidation events</h5>
                      <p class="text-muted mb-0 small">
                        Every time an admin edits a role's permission set or moves a user to a different role,
                        affected users are forced to re-login on their next request. This feed surfaces the
                        last 50 such events so you can answer <em>"who got logged out at 14:32 when the Auditor
                        role was edited?"</em> without grepping the raw audit log.
                      </p>
                    </div>
                  </div>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'Perm Bump', total: rows.length, newUrl: null, newLabel: null }) %>

                  <% if (rows.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-zap', title: 'No permission bumps yet', message: 'This feed is populated when an admin edits a role (e.g. grants/removes a permission) or moves a user to a different role. Both events trigger session invalidation for the affected users.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Timestamp</th>
                            <th>Triggered by</th>
                            <th>Action</th>
                            <th>Affected</th>
                            <th class="text-end">Invalidated</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% rows.forEach(function(r) { %>
                            <tr>
                              <td><span title="<%= r.createdAt.toISOString() %>"><%= new Date(r.createdAt).toLocaleString() %></span></td>
                              <td>
                                <% if (r.triggeredByEmail) { %>
                                  <%= r.triggeredByName %><br>
                                  <code class="small text-muted"><%= r.triggeredByEmail %></code>
                                <% } else { %>
                                  System
                                <% } %>
                              </td>
                              <td>
                                <% if (r.action === 'role.update') { %>
                                  <span class="badge bg-primary">role.update</span>
                                <% } else { %>
                                  <span class="badge bg-info">user.role-change</span>
                                <% } %>
                              </td>
                              <td>
                                <% if (r.action === 'role.update') { %>
                                  <strong><%= r.roleName || '(unknown role)' %></strong><br>
                                  <span class="text-muted small">Role's permission set changed</span>
                                <% } else { %>
                                  <strong><%= r.affectedUserName || '(unknown user)' %></strong>
                                  <% if (r.affectedUserEmail) { %><br><code class="small text-muted"><%= r.affectedUserEmail %></code><% } %><br>
                                  <span class="text-muted small">Moved between roles</span>
                                <% } %>
                              </td>
                              <td class="text-end">
                                <span class="badge bg-warning text-dark fs-6">
                                  <i class="bx bx-user-x me-1"></i><%= r.invalidatedCount %>
                                </span>
                              </td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
