<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',      href: '/' },
                    { label: 'Inventory', href: '/licenses' },
                    { label: 'Software Licenses', href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <%- include('../../partials/filter-toolbar', { filters: ['search'], query: query, action: '/licenses', resetUrl: '/licenses', searchPlaceholder: 'Name or license key…' }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'License', total: licenses.length, newUrl: '/licenses/new', newLabel: 'New License' }) %>

                  <% if (licenses.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-key', title: 'No software licenses yet', message: 'Track license keys, seats, vendors, and expiry dates. Click "+ New License" to add one.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Name</th>
                            <th>Vendor</th>
                            <th>License key</th>
                            <th>Seats</th>
                            <th>Expiry</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% licenses.forEach(function(l) { %>
                            <tr>
                              <td><strong><%= l.name %></strong></td>
                              <td><% if (l.vendorId) { var v = ((sources && sources.vendors) || []).find(function(v){ return v.id === l.vendorId; }); %><%= v ? v.name : '—' %><% } else { %>—<% } %></td>
                              <td><code class="small text-muted"><%= l.licenseKey || '—' %></code></td>
                              <td><%= l.seatsTotal || '—' %></td>
                              <td><%= l.expiryDate ? new Date(l.expiryDate).toLocaleDateString() : '—' %></td>
                              <td class="text-end"><%- include('../../partials/row-actions', { slug: 'licenses', id: l.id, capLc: 'license' }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
