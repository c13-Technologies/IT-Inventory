<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',       href: '/' },
                    { label: 'Directory',  href: '/departments' },
                    { label: 'Departments',href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <%- include('../../partials/filter-toolbar', { filters: ['search'], query: query, action: '/departments', resetUrl: '/departments', searchPlaceholder: 'Name or code…' }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'Department', total: departments.length, modalTarget: '#crudModal', slug: 'departments', cap: 'Department', newLabel: 'New Department' }) %>

                  <% if (departments.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-buildings', title: 'No departments yet', message: 'Group users into departments (IT, Engineering, Sales, …) and designate department heads. Click "+ New Department" to add one.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Name</th>
                            <th>Code</th>
                            <th>Head</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% departments.forEach(function(d) { %>
                            <tr>
                              <td><strong><%= d.name %></strong></td>
                              <td><code><%= d.code || '—' %></code></td>
                              <td><% if (d.headId) { var h = ((sources && sources.users) || []).find(function(u){ return u.id === d.headId; }); %><%= h ? h.fullName : '<code class="text-muted">' + d.headId + '</code>' %><% } else { %>—<% } %></td>
                              <td class="text-end"><%- include('../../partials/row-actions', { slug: 'departments', id: d.id, capLc: 'department', modalMode: true }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <% var _dMap = {}; departments.forEach(function(d) { _dMap[d.id] = d; }); %>
          <script>window.__CRUD_ROWS__ = <%- JSON.stringify(_dMap) %>;</script>

          <%- include('../../partials/modals/crud-modal', { slug: 'departments', cap: 'Department', schema: (typeof schema !== 'undefined' ? schema : []), sources: (typeof sources !== 'undefined' ? sources : {}) }) %>
          <%- include('../../partials/modals/delete-modal') %>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
