<%- include('../partials/head', { title: 'Login' }) %>

<body>

    <div class="auth-page">
        <div class="container-fluid p-0">
            <div class="row g-0">
                <div class="col-xxl-3 col-lg-4 col-md-5">
                    <div class="auth-full-page-content d-flex p-sm-5 p-4">
                        <div class="w-100">
                            <div class="d-flex flex-column h-100">
                                <div class="mb-4 mb-md-5 text-center">
                                    <a href="/" class="d-block auth-logo">
                                        <img src="assets/images/logo-sm.svg" alt="" height="28"> <span class="logo-txt">CLARITY</span>
                                    </a>
                                </div>
                                <div class="auth-content my-auto">
                                    <div class="text-center">
                                        <h5 class="mb-0">Welcome Back!</h5>
                                        <p class="text-muted mt-2">Sign in to IT Inventory.</p>
                                    </div>

                                    <% var _isLocked = (typeof lockedUntil !== 'undefined' && lockedUntil); %>
                                    <% if (_isLocked) { %>
                                        <div class="alert alert-warning alert-dismissible fade show mt-3" role="alert" data-locked-until="<%= lockedUntil %>" data-locked-seconds="<%= Math.max(0, Math.ceil((new Date(lockedUntil).getTime() - Date.now()) / 1000)) %>">
                                            <i class="bx bx-time-five me-1"></i><strong>Too many login attempts.</strong> To protect your account, sign-in is paused. You can try again in <span class="locked-countdown">--:--</span>.
                                        </div>
                                    <% } %>
                                    <% if (typeof error !== 'undefined' && error) { %>
                                        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                                            <i class="bx bx-error-circle me-1"></i><%= error %>
                                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                        </div>
                                    <% } %>
                                    <% if (typeof message !== 'undefined' && message) { %>
                                        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                                            <i class="bx bx-check-circle me-1"></i><%= message %>
                                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                        </div>
                                    <% } %>

                                    <form class="mt-4 pt-2" method="POST" action="/login">
                                        <div class="mb-3">
                                            <label for="email" class="form-label">Email</label>
                                            <input type="email" class="form-control" id="email" name="email" placeholder="you@company.com" required autofocus <%= _isLocked ? 'disabled' : '' %>>
                                        </div>
                                        <div class="mb-3">
                                            <div class="d-flex align-items-start">
                                                <div class="flex-grow-1">
                                                    <label class="form-label" for="password">Password</label>
                                                </div>
                                                <div class="flex-shrink-0">
                                                    <a href="#" class="text-muted">Forgot password?</a>
                                                </div>
                                            </div>

                                            <div class="input-group auth-pass-inputgroup">
                                                <input type="password" class="form-control" id="password" name="password" placeholder="Enter password" aria-label="Password" aria-describedby="password-addon" required <%= _isLocked ? 'disabled' : '' %>>
                                                <button class="btn btn-light shadow-none ms-0" type="button" id="password-addon" <%= _isLocked ? 'disabled' : '' %>><i class="mdi mdi-eye-outline"></i></button>
                                            </div>
                                        </div>
                                        <% if (_isLocked) { %>
                                            <input type="hidden" name="_locked" value="1">
                                        <% } %>
                                        <div class="row mb-4">
                                            <div class="col">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="remember-check" <%= _isLocked ? 'disabled' : '' %>>
                                                    <label class="form-check-label" for="remember-check">Remember me</label>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <button class="btn btn-primary w-100 waves-effect waves-light" type="submit" <%= _isLocked ? 'disabled' : '' %>>
                                                <% if (_isLocked) { %><i class="bx bx-lock me-1"></i>Sign-in paused<% } else { %>Sign In<% } %>
                                            </button>
                                        </div>
                                    </form>

                                    <div class="mt-4 pt-2 text-center">
                                        <div class="signin-other-title">
                                            <h5 class="font-size-14 mb-3 text-muted fw-medium">- Demo Accounts -</h5>
                                        </div>

                                        <div class="small">
                                            <p class="text-muted mb-1">All accounts use password: <code>password123</code></p>
                                            <span class="badge bg-primary me-1">alex.bytestorm@c13-tech.com</span>
                                            <span class="badge bg-info me-1">billy.nick@c13-tech.com</span>
                                            <span class="badge bg-secondary">lydia.acheng@c13-tech.com</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-4 mt-md-5 text-center">
                                    <p class="mb-0">&copy;
                                        <script>document.write(new Date().getFullYear())</script>
                                        C13 Technologies. Crafted with <i class="mdi mdi-heart text-danger"></i> by the team
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- end auth full page content -->
                </div>
                <!-- end col -->
                <div class="col-xxl-9 col-lg-8 col-md-7">
                    <div class="auth-bg pt-md-5 p-4 d-flex">
                        <div class="bg-overlay bg-primary"></div>
                        <ul class="bg-bubbles">
                            <li></li>
                            <li></li>
                            <li></li>
                            <li></li>
                            <li></li>
                            <li></li>
                            <li></li>
                            <li></li>
                            <li></li>
                            <li></li>
                        </ul>
                        <!-- end bubble effect -->
                        <div class="row justify-content-center align-items-center">
                            <div class="col-xl-7">
                                <div class="p-0 p-sm-4 px-xl-0">
                                    <div id="reviewcarouselIndicators" class="carousel slide" data-bs-ride="carousel">
                                        <div class="carousel-indicators carousel-indicators-rounded justify-content-start ms-0 mb-0">
                                            <button type="button" data-bs-target="#reviewcarouselIndicators" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                                            <button type="button" data-bs-target="#reviewcarouselIndicators" data-bs-slide-to="1" aria-label="Slide 2"></button>
                                            <button type="button" data-bs-target="#reviewcarouselIndicators" data-bs-slide-to="2" aria-label="Slide 3"></button>
                                        </div>
                                        <div class="carousel-inner">
                                            <div class="carousel-item active">
                                                <div class="testi-contain text-white">
                                                    <i class="bx bxs-quote-alt-left text-success display-6"></i>
                                                    <h4 class="mt-4 fw-medium lh-base text-white">"Track every asset, from procurement to retirement. Know exactly what you own, where it is, and who has it."</h4>
                                                    <div class="mt-4 pt-3 pb-5">
                                                        <div class="d-flex align-items-start">
                                                            <div class="flex-shrink-0">
                                                                <img src="assets/images/users/avatar-2.png" class="avatar-md img-fluid rounded-circle" alt="...">
                                                            </div>
                                                            <div class="flex-grow-1 ms-3 mb-4">
                                                                <h5 class="font-size-18 text-white">Alex Bytestorm</h5>
                                                                <p class="mb-0 text-white-50">IT Manager</p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="carousel-item">
                                                <div class="testi-contain text-white">
                                                    <i class="bx bxs-quote-alt-left text-success display-6"></i>
                                                    <h4 class="mt-4 fw-medium lh-base text-white">"The assignment system makes onboarding a breeze. New hires get their gear fast and we always know who has what."</h4>
                                                    <div class="mt-4 pt-3 pb-5">
                                                        <div class="d-flex align-items-start">
                                                            <div class="flex-shrink-0">
                                                                <img src="assets/images/users/avatar-5.png" class="avatar-md img-fluid rounded-circle" alt="...">
                                                            </div>
                                                            <div class="flex-grow-1 ms-3 mb-4">
                                                                <h5 class="font-size-18 text-white">Billy Nick</h5>
                                                                <p class="mb-0 text-white-50">IT Support</p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="carousel-item">
                                                <div class="testi-contain text-white">
                                                    <i class="bx bxs-quote-alt-left text-success display-6"></i>
                                                    <h4 class="mt-4 fw-medium lh-base text-white">"Maintenance tracking and warranty alerts keep us ahead of issues. No more missed renewals or surprise repair costs."</h4>
                                                    <div class="mt-4 pt-3 pb-5">
                                                        <div class="d-flex align-items-start">                                                                <img src="assets/images/users/avatar-4.jpg" class="avatar-md img-fluid rounded-circle" alt="...">
                                                            <div class="flex-1 ms-3 mb-4">
                                                                <h5 class="font-size-18 text-white">Sande Ochieno</h5>
                                                                <p class="mb-0 text-white-50">Department Head</p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- end col -->
            </div>
            <!-- end row -->
        </div>
        <!-- end container fluid -->
    </div>

    <%- include('../partials/scripts-auth') %>
    <!-- password show/hide toggle -->
    <script src="assets/js/pages/pass-addon.init.js"></script>

    <!-- Lockout countdown: 1Hz tick on the warning banner; reloads the page once the wait elapses so the user can try again. -->
    <script>
    (function () {
      var el = document.querySelector('[data-locked-until]');
      if (!el) return;
      var target = new Date(el.dataset.lockedUntil).getTime();
      var span = el.querySelector('.locked-countdown');
      function pad(n) { return n < 10 ? '0' + n : '' + n; }
      function tick() {
        var ms = target - Date.now();
        if (ms <= 0) { location.reload(); return; }
        var m = Math.floor(ms / 60000);
        var s = Math.floor((ms % 60000) / 1000);
        span.textContent = pad(m) + ':' + pad(s);
        setTimeout(tick, 1000);
      }
      tick();
      // Defensive: if the page stays open across the boundary without a
      // reload (e.g. user backgrounds the tab), still nudge a refresh a few
      // seconds after expiry.
      setTimeout(function () { location.reload(); }, Math.max(0, target - Date.now()) + 5000);
    })();
    </script>

</body>
</html>
