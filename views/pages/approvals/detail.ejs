<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

<% const renderValue = function(row, f, sources) {
     if (!row || row[f.key] === undefined || row[f.key] === null || row[f.key] === '') return '—';
     if (f.type === 'select-fk') {
       var items = (sources && sources[f.source]) || [];
       var found = items.find(function(x){ return x.id === row[f.key]; });
       return found ? (found.name || found.fullName || found.id) : row[f.key];
     }
     if (f.type === 'date') return String(row[f.key]).slice(0, 10);
     return String(row[f.key]).replace(/_/g, ' ');
   }; %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home', href: '/' },
                    { label: parentCrumb, href: '/' + slug },
                    { label: title, href: null }
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-lg-8">
              <div class="card">
                <div class="card-body">
                  <% if (errors && errors._global) { %>
                    <div class="alert alert-danger"><i class="bx bx-error-circle me-1"></i><%= errors._global %></div>
                  <% } %>
                  <dl class="row mb-0">
                    <% (schema || []).forEach(function(f) { %>
                      <dt class="col-sm-4 text-muted fw-normal"><%= f.label %></dt>
                      <dd class="col-sm-8"><%- renderValue(row, f, sources) %></dd>
                    <% }); %>
                    <dt class="col-sm-4 text-muted fw-normal">ID</dt>
                    <dd class="col-sm-8"><code class="text-muted"><%= row.id %></code></dd>
                  </dl>
                </div>
                <div class="card-footer d-flex gap-2">
                  <a href="/<%= slug %>/<%= row.id %>/edit" class="btn btn-primary">
                    <i class="bx bx-edit me-1"></i>Edit
                  </a>
                  <a href="/<%= slug %>" class="btn btn-light">
                    <i class="bx bx-arrow-back me-1"></i>Back to list
                  </a>
                  <form method="POST" action="/<%= slug %>/<%= row.id %>/delete"
                        onsubmit="return confirm('Delete this <%= capLc %>? This cannot be undone.');"
                        class="ms-auto">
                    <button type="submit" class="btn btn-outline-danger">
                      <i class="bx bx-trash me-1"></i>Delete
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
