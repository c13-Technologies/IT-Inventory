<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',   href: '/' },
                    { label: 'Admin',  href: '/audit-log' },
                    { label: 'Audit Log', href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <div class="d-flex align-items-start mb-3">
                    <div class="flex-grow-1">
                      <h5 class="card-title mb-1">Administrative action log</h5>
                      <p class="text-muted mb-0 small">
                        Every create, update, delete, role change, and
                        previous CSV export is recorded here with
                        before/after snapshots — immutable and append-only.
                        Use the export below for compliance reviews
                        (<em>"give me last quarter's action log"</em>).
                      </p>
                    </div>
                    <div class="ms-3 flex-shrink-0">
                      <a href="/api/audit-log/export.csv"
                         class="btn btn-outline-secondary btn-sm px-3 py-2"
                         style="min-width: 44px; min-height: 44px;"
                         download
                         title="Download the most recent audit log entries (up to 5,000) as a CSV file (admin:read gate, streaming, RFC 4180). If your tenant has more than 5,000 rows, only the newest 5,000 are returned \u— re-export after pruning for a complete dump. The export itself is recorded in the audit log so compliance can cross-reference the filename against the puller. Note: the export contains user_email and IP columns (PII in many jurisdictions â confirm your compliance regime before sharing the file externally)."
                         aria-label="Download the most recent audit log entries (up to 5,000) as CSV">
                        <i class="bx bx-download me-1" aria-hidden="true"></i>Export CSV
                      </a>
                    </div>
                  </div>

                  <%- include('../../partials/filter-toolbar', { filters: ['search'], query: query, action: '/audit-log', resetUrl: '/audit-log', searchPlaceholder: 'Action, entity type, or user…' }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'Audit Entry', total: entries.length, newUrl: null, newLabel: null }) %>

                  <% if (entries.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-history', title: 'No audit entries yet', message: 'Every create, update, and delete action is recorded here with before/after snapshots — immutable and append-only.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Timestamp</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Entity</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% entries.forEach(function(e) { %>
                            <tr>
                              <td><%= e.createdAt ? new Date(e.createdAt).toLocaleString() : '—' %></td>
                              <td><%= e.userName || 'System' %></td>
                              <td><span class="badge bg-dark"><%= e.action %></span></td>
                              <td><%= e.entityType %> <code class="small text-muted"><%= e.entityId %></code></td>
                              <td class="text-end"><%- include('../../partials/row-actions', { slug: 'audit-log', id: e.id, capLc: 'auditEntry' }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
