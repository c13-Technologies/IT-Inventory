<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',      href: '/' },
                    { label: 'Directory', href: '/vendors' },
                    { label: 'Vendors',   href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <%- include('../../partials/filter-toolbar', {
                    filters: ['search', 'status'],
                    query: query,
                    statusOptions: (typeof statusOptions !== 'undefined' && statusOptions !== null) ? statusOptions : ['', 'ACTIVE', 'INACTIVE'],
                    action: '/vendors',
                    resetUrl: '/vendors',
                    searchPlaceholder: 'Name, contact, or email…'
                  }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'Vendor', total: vendors.length, modalTarget: '#crudModal', slug: 'vendors', cap: 'Vendor', newLabel: 'New Vendor' }) %>

                  <% if (vendors.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-store', title: 'No vendors yet', message: 'Add a vendor to start tracking who you buy hardware and services from.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Name</th>
                            <th>Contact</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% vendors.forEach(function(v) { %>
                            <tr>
                              <td><strong><%= v.name %></strong></td>
                              <td><%= v.contactPerson || '—' %></td>
                              <td><a href="mailto:<%= v.email %>" class="text-reset"><%= v.email || '—' %></a></td>
                              <td><%= v.phone || '—' %></td>
                              <td><span class="badge bg-<%= v.status === 'ACTIVE' ? 'success' : 'secondary' %>"><%= v.status %></span></td>
                              <td class="text-end"><%- include('../../partials/row-actions', { slug: 'vendors', id: v.id, capLc: 'vendor', modalMode: true, viewMode: 'modal', viewModalTarget: '#viewVendorModal' }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <% var _vMap = {}; vendors.forEach(function(v) { _vMap[v.id] = v; }); %>
          <script>window.__CRUD_ROWS__ = <%- JSON.stringify(_vMap) %>;</script>

          <%- include('../../partials/modals/crud-modal', { slug: 'vendors', cap: 'Vendor', schema: (typeof schema !== 'undefined' ? schema : []), sources: (typeof sources !== 'undefined' ? sources : {}) }) %>
          <%- include('../../partials/modals/delete-modal') %>
          <%- include('../../partials/modals/view-vendor') %>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
