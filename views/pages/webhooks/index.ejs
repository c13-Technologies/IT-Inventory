<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',            href: '/' },
                    { label: 'Communications',  href: '/webhooks' },
                    { label: 'Webhooks',        href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <%- include('../../partials/filter-toolbar', {
                    filters: ['search', 'status'],
                    query: query,
                    statusOptions: (typeof statusOptions !== 'undefined' && statusOptions !== null) ? statusOptions : ['', 'SLACK', 'TEAMS'],
                    action: '/webhooks',
                    resetUrl: '/webhooks',
                    searchPlaceholder: 'URL or event type…'
                  }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'Webhook', total: webhooks.length, newUrl: '/webhooks/new', newLabel: 'New Webhook' }) %>

                  <% if (webhooks.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-webhook', title: 'No webhooks configured', message: 'Send real-time events to Slack or Teams — asset assignments, approvals, warranty alerts, and more.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Channel</th>
                            <th>URL</th>
                            <th>Events</th>
                            <th>Last Delivery</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% webhooks.forEach(function(w) { %>
                            <tr>
                              <td><span class="badge bg-<%= w.channel === 'SLACK' ? 'success' : 'primary' %>"><%= w.channel %></span></td>
                              <td><code class="small text-muted"><%= (w.url || '').substring(0, 40) %>…</code></td>
                              <td><% (w.events || []).forEach(function(ev) { %><span class="badge bg-light text-dark me-1"><%= ev %></span><% }); %></td>
                              <td><%= w.lastDeliveredAt ? new Date(w.lastDeliveredAt).toLocaleString() : 'Never' %></td>
                              <td class="text-end"><%- include('../../partials/row-actions', { slug: 'webhooks', id: w.id, capLc: 'webhook' }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
