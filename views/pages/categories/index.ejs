<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',      href: '/' },
                    { label: 'Directory', href: '/categories' },
                    { label: 'Categories',href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <%- include('../../partials/filter-toolbar', { filters: ['search','status'], query: query, statusOptions: (typeof statusOptions !== 'undefined' && statusOptions !== null) ? statusOptions : ['','HARDWARE','SOFTWARE','PERIPHERAL','ACCESSORY'], action: '/categories', resetUrl: '/categories', searchPlaceholder: 'Name…' }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'Category', total: categories.length, modalTarget: '#crudModal', slug: 'categories', cap: 'Category', newLabel: 'New Category' }) %>

                  <% if (categories.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-category', title: 'No categories yet', message: 'Define categories (Laptops, Monitors, Software Licenses, etc.) so assets can be classified.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Parent</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% categories.forEach(function(c) { %>
                            <tr>
                              <td><strong><%= c.name %></strong></td>
                              <td><span class="badge bg-primary-subtle text-primary"><%= c.type %></span></td>
                              <td class="text-muted small"><%= c.description || '—' %></td>
                              <td><%- c.parentId ? '<code class="text-muted">' + c.parentId + '</code>' : '<span class="text-muted">— top-level —</span>' %></td>
                              <td class="text-end"><%- include('../../partials/row-actions', { slug: 'categories', id: c.id, capLc: 'category', modalMode: true }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <% var _cMap = {}; categories.forEach(function(c) { _cMap[c.id] = c; }); %>
          <script>window.__CRUD_ROWS__ = <%- JSON.stringify(_cMap) %>;</script>

          <%- include('../../partials/modals/crud-modal', { slug: 'categories', cap: 'Category', schema: (typeof schema !== 'undefined' ? schema : []), sources: (typeof sources !== 'undefined' ? sources : {}) }) %>
          <%- include('../../partials/modals/delete-modal') %>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
