<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',      href: '/' },
                    { label: 'Directory', href: '/locations' },
                    { label: 'Locations', href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <%- include('../../partials/filter-toolbar', { filters: ['search'], query: query, action: '/locations', resetUrl: '/locations', searchPlaceholder: 'Name or address…' }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'Location', total: locations.length, modalTarget: '#crudModal', slug: 'locations', cap: 'Location', newLabel: 'New Location' }) %>

                  <% if (locations.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-map', title: 'No locations yet', message: 'Add offices, datacenters, and remote sites to track where assets live.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Address</th>
                            <th>Parent</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% locations.forEach(function(l) { %>
                            <tr>
                              <td><strong><%= l.name %></strong></td>
                              <td><span class="badge bg-info-subtle text-info"><%= (l.type || '').replace(/_/g, ' ') %></span></td>
                              <td class="text-muted"><%= l.address || '—' %></td>
                              <td><%- l.parentId ? '<code class="text-muted">' + l.parentId + '</code>' : '<span class="text-muted">— top-level —</span>' %></td>
                              <td class="text-end"><%- include('../../partials/row-actions', { slug: 'locations', id: l.id, capLc: 'location', modalMode: true, viewMode: 'modal', viewModalTarget: '#viewLocationModal' }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <% var _lMap = {}; locations.forEach(function(l) { _lMap[l.id] = l; }); %>
          <script>window.__CRUD_ROWS__ = <%- JSON.stringify(_lMap) %>;</script>

          <%- include('../../partials/modals/crud-modal', { slug: 'locations', cap: 'Location', schema: (typeof schema !== 'undefined' ? schema : []), sources: (typeof sources !== 'undefined' ? sources : {}) }) %>
          <%- include('../../partials/modals/delete-modal') %>
          <%- include('../../partials/modals/view-location') %>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
