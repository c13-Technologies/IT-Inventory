<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',       href: '/' },
                    { label: 'Lifecycle',  href: '/warranty' },
                    { label: 'Warranty Tracking', href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <%- include('../../partials/filter-toolbar', {
                    filters: ['search', 'status'],
                    query: query,
                    statusOptions: (typeof statusOptions !== 'undefined' && statusOptions !== null) ? statusOptions : ['', 'ACTIVE', 'EXPIRING', 'EXPIRED'],
                    action: '/warranty',
                    resetUrl: '/warranty',
                    searchPlaceholder: 'Asset name or tag…'
                  }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'Warranty', total: warranties.length, newUrl: null, newLabel: null }) %>

                  <% if (warranties.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-shield-quarter', title: 'No warranty items', message: 'Track warranty expiry dates across all assets and get alerts before coverage runs out.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Asset</th>
                            <th>Vendor</th>
                            <th>Warranty Expiry</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% warranties.forEach(function(w) { %>
                            <tr>
                              <td><strong><%= w.assetName || '—' %></strong></td>
                              <td><%= w.vendorName || '—' %></td>
                              <td><%= w.expiryDate ? new Date(w.expiryDate).toLocaleDateString() : '—' %></td>
                              <td><span class="badge bg-<%= w.status === 'EXPIRED' ? 'danger' : w.status === 'EXPIRING' ? 'warning' : 'success' %>"><%= w.status %></span></td>
                              <td class="text-end"><%- include('../../partials/row-actions', { slug: 'warranty', id: w.id, capLc: 'warranty' }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
