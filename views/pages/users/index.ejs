<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',      href: '/' },
                    { label: 'Directory', href: '/users' },
                    { label: 'Users',     href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <%- include('../../partials/filter-toolbar', { filters: ['search','status'], query: query, statusOptions: (typeof statusOptions !== 'undefined' && statusOptions !== null) ? statusOptions : ['','IT_MANAGER','IT_SUPPORT','DEPARTMENT_HEAD','EMPLOYEE'], action: '/users', resetUrl: '/users', searchPlaceholder: 'Name or email…' }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'User', total: users.length, modalTarget: '#crudModal', slug: 'users', cap: 'User', newLabel: 'New User' }) %>

                  <% if (users.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-user', title: 'No users yet', message: 'Add users so they can be assigned assets and tracked through approvals.' }) %>
                  <% } else { %>
                    <% const roleColor = function(r){ if(r==='IT_MANAGER')return'primary'; if(r==='DEPARTMENT_HEAD')return'info'; if(r==='IT_SUPPORT')return'success'; return'secondary'; }; %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Full name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Department</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% users.forEach(function(u) { %>
                            <tr>
                              <td><strong><%= u.fullName %></strong></td>
                              <td><a href="mailto:<%= u.email %>" class="text-reset"><%= u.email %></a></td>
                              <td><span class="badge bg-<%= roleColor(u.role) %>"><%= (u.role || '').replace(/_/g, ' ') %></span></td>
                              <td><%- u.departmentId ? '<code class="text-muted">' + u.departmentId + '</code>' : '—' %></td>
                              <td><span class="badge bg-<%= u.status === 'ACTIVE' ? 'success' : u.status === 'PENDING' ? 'warning' : 'secondary' %>"><%= u.status || 'ACTIVE' %></span></td>
                              <td class="text-end"><%- include('../../partials/row-actions', { slug: 'users', id: u.id, capLc: 'user', modalMode: true }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <% var _uMap = {}; users.forEach(function(u) { _uMap[u.id] = u; }); %>
          <script>window.__CRUD_ROWS__ = <%- JSON.stringify(_uMap) %>;</script>

          <%- include('../../partials/modals/crud-modal', { slug: 'users', cap: 'User', schema: (typeof schema !== 'undefined' ? schema : []), sources: (typeof sources !== 'undefined' ? sources : {}) }) %>
          <%- include('../../partials/modals/delete-modal') %>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
