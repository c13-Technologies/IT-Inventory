<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home', href: '/' },
                    { label: 'Directory', href: '/users' },
                    { label: title, href: null }
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <!-- Profile Card -->
            <div class="col-lg-4">
              <div class="card">
                <div class="card-body text-center">
                  <div class="avatar-lg mx-auto mb-3">
                    <span class="avatar-title rounded-circle bg-primary-subtle text-primary font-size-24">
                      <%= (row.fullName || 'U').charAt(0).toUpperCase() %>
                    </span>
                  </div>
                  <h5 class="mb-1"><%= row.fullName %></h5>
                  <p class="text-muted mb-2"><% if (typeof row.role === 'string') { %><%= row.role.replace(/_/g, ' ') %><% } else { %>—<% } %></p>

                  <div class="text-start mt-4">
                    <div class="d-flex justify-content-between border-bottom py-2">
                      <span class="text-muted">Email</span>
                      <a href="mailto:<%= row.email %>" class="text-reset fw-medium"><%= row.email %></a>
                    </div>
                    <div class="d-flex justify-content-between border-bottom py-2">
                      <span class="text-muted">Status</span>
                      <span class="badge bg-<%= row.status === 'ACTIVE' ? 'success' : row.status === 'PENDING' ? 'warning' : 'secondary' %>"><%= row.status || 'ACTIVE' %></span>
                    </div>
                    <% if (row.department && row.department.name) { %>
                    <div class="d-flex justify-content-between border-bottom py-2">
                      <span class="text-muted">Department</span>
                      <span class="fw-medium"><%= row.department.name %></span>
                    </div>
                    <% } %>
                    <div class="d-flex justify-content-between border-bottom py-2">
                      <span class="text-muted">Last Login</span>
                      <span class="fw-medium"><%= row.lastLoginAt ? new Date(row.lastLoginAt).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit' }) : 'Never' %></span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom py-2">
                      <span class="text-muted">Joined</span>
                      <span class="fw-medium"><%= new Date(row.createdAt).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %></span>
                    </div>
                  </div>
                </div>
                <div class="card-footer d-flex gap-2">
                  <a href="/users/<%= row.id %>/edit" class="btn btn-primary btn-sm">
                    <i class="bx bx-edit me-1"></i>Edit
                  </a>
                  <a href="/users" class="btn btn-light btn-sm">Back</a>
                </div>
              </div>
            </div>

            <!-- Assigned Assets & Audit History -->
            <div class="col-lg-8">
              <!-- Active Assignments -->
              <div class="card">
                <div class="card-body">
                  <h5 class="card-title mb-3"><i class="bx bx-laptop me-1"></i>Assigned Assets</h5>
                  <% if (!row.activeAssignments || row.activeAssignments.length === 0) { %>
                    <p class="text-muted mb-0">No assets currently assigned.</p>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-sm table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Asset</th>
                            <th>Tag</th>
                            <th>Assigned</th>
                            <th>Notes</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% row.activeAssignments.forEach(function(a) { %>
                            <tr>
                              <td>
                                <strong><a href="/assets/<%= a.asset ? a.asset.id : '#' %>" class="text-reset"><%= a.asset ? a.asset.name : a.assetId %></a></strong>
                              </td>
                              <td><code class="text-muted"><%= a.asset ? a.asset.assetTag : '—' %></code></td>
                              <td class="text-muted small"><%= new Date(a.assignedAt).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) %></td>
                              <td class="text-muted small"><%= a.notes || '—' %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>

              <!-- Audit History -->
              <div class="card">
                <div class="card-body">
                  <h5 class="card-title mb-3"><i class="bx bx-history me-1"></i>Audit History</h5>
                  <% if (!row.auditLogs || row.auditLogs.length === 0) { %>
                    <p class="text-muted mb-0">No audit entries yet.</p>
                  <% } else { %>
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                      <table class="table table-sm table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Action</th>
                            <th>Entity</th>
                            <th>Date</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% row.auditLogs.forEach(function(l) { %>
                            <tr>
                              <td><span class="badge bg-<%= (l.action || '').includes('create') ? 'success' : (l.action || '').includes('delete') ? 'danger' : (l.action || '').includes('update') ? 'warning' : 'secondary' %>"><%= l.action %></span></td>
                              <td class="small"><%= l.entityType %> <code class="text-muted"><%= l.entityId.substring(0, 8) %>…</code></td>
                              <td class="text-muted small"><%= new Date(l.createdAt).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
