<%- include('../partials/head', { title: "Dashboard" }) %>

<body>

    <div id="layout-wrapper">

        <%- include('../partials/topbar') %>
        <%- include('../partials/sidebar') %>

        <div class="main-content">
            <div class="page-content">
                <div class="container-fluid">

                    <div class="row">
                        <div class="col-12">
                            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                                <h4 class="mb-sm-0 font-size-18">Dashboard</h4>
                                <div class="page-title-right">
                                    <ol class="breadcrumb m-0">
                                        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                                        <li class="breadcrumb-item active">Overview</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-xl-3 col-md-6">
                            <div class="card card-h-100">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-grow-1">
                                            <span class="text-muted mb-3 lh-1 d-block text-truncate">Total Assets</span>
                                            <h4 class="mb-3" id="stat-total-assets">--</h4>
                                        </div>
                                        <div class="flex-shrink-0">
                                            <div class="avatar-sm">
                                                <span class="avatar-title bg-primary-subtle rounded text-primary font-size-24">
                                                    <i class="mdi mdi-harddisk"></i>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div id="sparkline-assets" data-colors='["#5156be"]' class="apex-charts spark-card bg-primary-subtle rounded mb-3" style="height: 38px;"></div>
                                    <div class="d-flex align-items-center justify-content-between">
                                        <a href="/assets" class="text-decoration-underline text-muted font-size-13">View all assets <i class="mdi mdi-arrow-right"></i></a>
                                        <span class="text-muted font-size-11" id="sparkline-assets-total">-- in 7d</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card card-h-100">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-grow-1">
                                            <span class="text-muted mb-3 lh-1 d-block text-truncate">Assigned Assets</span>
                                            <h4 class="mb-3" id="stat-assigned">--</h4>
                                        </div>
                                        <div class="flex-shrink-0">
                                            <div class="avatar-sm">
                                                <span class="avatar-title bg-success-subtle rounded text-success font-size-24">
                                                    <i class="mdi mdi-account-check"></i>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div id="sparkline-assignments" data-colors='["#34c38f"]' class="apex-charts spark-card bg-success-subtle rounded mb-3" style="height: 38px;"></div>
                                    <div class="d-flex align-items-center justify-content-between">
                                        <a href="/assignments" class="text-decoration-underline text-muted font-size-13">View assignments <i class="mdi mdi-arrow-right"></i></a>
                                        <span class="text-muted font-size-11" id="sparkline-assignments-total">-- in 7d</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card card-h-100">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-grow-1">
                                            <span class="text-muted mb-3 lh-1 d-block text-truncate">Users</span>
                                            <h4 class="mb-3" id="stat-users">--</h4>
                                        </div>
                                        <div class="flex-shrink-0">
                                            <div class="avatar-sm">
                                                <span class="avatar-title bg-info-subtle rounded text-info font-size-24">
                                                    <i class="mdi mdi-account-group"></i>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div id="sparkline-users" data-colors='["#50a5f1"]' class="apex-charts spark-card bg-info-subtle rounded mb-3" style="height: 38px;"></div>
                                    <div class="d-flex align-items-center justify-content-between">
                                        <a href="/users" class="text-decoration-underline text-muted font-size-13">View directory <i class="mdi mdi-arrow-right"></i></a>
                                        <span class="text-muted font-size-11" id="sparkline-users-total">-- in 7d</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-3 col-md-6">
                            <div class="card card-h-100">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-grow-1">
                                            <span class="text-muted mb-3 lh-1 d-block text-truncate">Vendors &amp; Locations</span>
                                            <h4 class="mb-3"><span id="stat-vendors">--</span> / <span id="stat-locations">--</span></h4>
                                        </div>
                                        <div class="flex-shrink-0">
                                            <div class="avatar-sm">
                                                <span class="avatar-title bg-warning-subtle rounded text-warning font-size-24">
                                                    <i class="mdi mdi-office-building"></i>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                    <div id="sparkline-vendors" data-colors='["#f1b44c"]' class="apex-charts spark-card bg-warning-subtle rounded mb-3" style="height: 38px;"></div>
                                    <div class="d-flex align-items-center justify-content-between flex-wrap">
                                        <div>
                                            <a href="/vendors" class="text-decoration-underline text-muted font-size-13">Vendors <i class="mdi mdi-arrow-right"></i></a>
                                            <span class="text-muted mx-1">|</span>
                                            <a href="/locations" class="text-decoration-underline text-muted font-size-13">Locations <i class="mdi mdi-arrow-right"></i></a>
                                        </div>
                                        <span class="text-muted font-size-11" id="sparkline-vendors-total">-- new in 7d</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-xl-7">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title mb-4">Assets by Category</h5>
                                    <div id="chart-assets-by-category" data-colors='["#5156be","#34c38f","#f1b44c","#f46a6a","#50a5f1","#74788d","#6f42c1","#e83e8c"]' class="apex-charts" style="height: 320px;"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-5">
                            <div class="card card-h-100">
                                <div class="card-body">
                                    <h5 class="card-title mb-4">Assets by Status</h5>
                                    <div id="chart-assets-by-status" data-colors='["#34c38f","#5156be","#f1b44c","#f46a6a","#74788d"]' class="apex-charts" style="height: 320px;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- end charts row -->

                    <!-- Recent activity + Quick Stats row -->
                    <div class="row">
                        <div class="col-xl-8">
                            <div class="card">
                                <div class="card-header align-items-center d-flex">
                                    <h4 class="card-title mb-0 flex-grow-1">Recent Activity</h4>
                                    <div class="flex-shrink-0">
                                        <a href="/audit-log" class="btn btn-soft-primary btn-sm">Full Audit Log <i class="mdi mdi-arrow-right ms-1"></i></a>
                                    </div>
                                </div>
                                <div class="card-body px-0">
                                    <div class="px-3" data-simplebar style="max-height: 360px;">
                                        <ul class="list-unstyled activity-wid mb-0" id="recent-activity-list">
                                            <li class="activity-list activity-border text-center text-muted py-4">
                                                <i class="mdi mdi-loading mdi-spin font-size-20"></i> Loading activity...
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-4">
                            <div class="card card-h-100">
                                <div class="card-body">
                                    <h5 class="card-title mb-4">Quick Stats</h5>
                                    <p class="mb-1">In Repair <span class="float-end" id="qs-in-repair">--</span></p>
                                    <div class="progress mt-2" style="height: 6px;">
                                        <div class="progress-bar bg-warning" role="progressbar" id="qs-bar-inrepair" style="width: 0%"></div>
                                    </div>
                                    <p class="mt-3 mb-1">Retired <span class="float-end" id="qs-retired">--</span></p>
                                    <div class="progress mt-2" style="height: 6px;">
                                        <div class="progress-bar bg-danger" role="progressbar" id="qs-bar-retired" style="width: 0%"></div>
                                    </div>
                                    <p class="mt-3 mb-1">In Stock <span class="float-end" id="qs-instock">--</span></p>
                                    <div class="progress mt-2" style="height: 6px;">
                                        <div class="progress-bar bg-success" role="progressbar" id="qs-bar-instock" style="width: 0%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- end recent activity row -->

                </div>
            </div>
        </div>

        <%- include('../partials/footer') %>
    </div>

    <%- include('../partials/scripts', { pageScripts: typeof pageScripts !== 'undefined' ? pageScripts : [] }) %>
</body>
</html>
                 
