<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',   href: '/' },
                    { label: 'Admin',  href: '/reports' },
                    { label: 'Reports', href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <%- include('../../partials/filter-toolbar', { filters: ['search'], query: query, action: '/reports', resetUrl: '/reports', searchPlaceholder: 'Report name…' }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'Report', total: reports.length, newUrl: '/reports/new', newLabel: 'New Report' }) %>

                  <% if (reports.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-bar-chart-square', title: 'No reports yet', message: 'Generate asset utilization summaries, depreciation schedules, compliance audits, and custom reports.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Generated</th>
                            <th>Format</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% reports.forEach(function(r) { %>
                            <tr>
                              <td><strong><%= r.name %></strong></td>
                              <td><span class="badge bg-primary"><%= r.type %></span></td>
                              <td><%= r.generatedAt ? new Date(r.generatedAt).toLocaleDateString() : '—' %></td>
                              <td><span class="badge bg-secondary"><%= r.format || 'PDF' %></span></td>
                              <td class="text-end"><%- include('../../partials/row-actions', { slug: 'reports', id: r.id, capLc: 'report' }) %></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
