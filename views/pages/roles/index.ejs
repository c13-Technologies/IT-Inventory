<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18"><%= title %></h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home',   href: '/' },
                    { label: 'Admin',  href: '/roles' },
                    { label: 'Roles &amp; Permissions', href: null },
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="card">
                <div class="card-body">
                  <%- include('../../partials/filter-toolbar', { filters: ['search'], query: query, action: '/roles', resetUrl: '/roles', searchPlaceholder: 'Role name or description…' }) %>

                  <hr class="mt-3 mb-3">

                  <%- include('../../partials/list-toolbar', { title: 'Role', total: roles.length, newUrl: '/roles/new', newLabel: 'New Role' }) %>

                  <% if (roles.length === 0) { %>
                    <%- include('../../partials/empty-state', { icon: 'bx-shield-alt', title: 'No custom roles defined', message: 'Manage role-based access control — define roles, assign permissions, and control who can do what.' }) %>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Permissions</th>
                            <th>Users</th>
                            <th class="text-end">Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% roles.forEach(function(r) { %>
                            <tr>
                              <td>
                                <strong><a href="/roles/<%= r.id %>" class="text-reset"><%= r.name %></a></strong>
                                <% if (r.isBuiltin) { %> <span class="badge bg-info ms-1">built-in</span><% } else { %> <span class="badge bg-secondary ms-1">custom</span><% } %>
                              </td>
                              <td><%= r.description || '—' %></td>
                              <td><span class="badge bg-secondary"><%= (r.permissionCount || 0) %></span></td>
                              <td><span class="badge bg-light text-dark"><%= (r.userCount || 0) %></span></td>
                              <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                  <a href="/roles/<%= r.id %>" class="btn btn-sm btn-soft-primary" title="View"><i class="bx bx-show"></i></a>
                                  <% if (!r.isBuiltin) { %>
                                    <a href="/roles/<%= r.id %>/edit" class="btn btn-sm btn-soft-secondary" title="Edit"><i class="bx bx-edit"></i></a>
                                    <form method="POST" action="/roles/<%= r.id %>/delete" onsubmit="return confirm('Delete this role? Users still mapped to it must be reassigned first.');" style="display:inline">
                                      <button type="submit" class="btn btn-sm btn-soft-danger" title="Delete"><i class="bx bx-trash"></i></button>
                                    </form>
                                  <% } else { %>
                                    <span class="btn btn-sm btn-soft-secondary disabled" style="opacity:0.4" title="Built-in roles cannot be edited from the UI"><i class="bx bx-edit"></i></span>
                                    <span class="btn btn-sm btn-soft-danger disabled" style="opacity:0.4" title="Built-in roles cannot be deleted"><i class="bx bx-trash"></i></span>
                                  <% } %>
                                </div>
                              </td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
