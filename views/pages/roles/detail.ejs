<%- include('../../partials/head', { title: title }) %>

<body>
  <div id="layout-wrapper">
    <%- include('../../partials/topbar') %>
    <%- include('../../partials/sidebar') %>

    <div class="main-content">
      <div class="page-content">
        <div class="container-fluid">

          <div class="row">
            <div class="col-12">
              <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0 font-size-18">
                  <%= title %>
                  <% if (row.isBuiltin) { %><span class="badge bg-info ms-2">built-in</span><% } else { %><span class="badge bg-secondary ms-2">custom</span><% } %>
                </h4>
                <div class="page-title-right">
                  <%- include('../../partials/breadcrumb', { items: [
                    { label: 'Home', href: '/' },
                    { label: 'Admin', href: '/roles' },
                    { label: title, href: null }
                  ] }) %>
                </div>
              </div>
            </div>
          </div>

          <% if (errors && errors._global) { %>
            <div class="alert alert-danger d-flex align-items-center" role="alert">
              <i class="bx bx-error-circle me-2"></i><%= errors._global %>
            </div>
          <% } %>

          <div class="row">
            <!-- Left column: identity + actions -->
            <div class="col-lg-4">
              <div class="card">
                <div class="card-body text-center">
                  <div class="avatar-lg mx-auto mb-3">
                    <span class="avatar-title rounded-circle bg-primary-subtle text-primary font-size-24">
                      <i class="bx bx-shield-alt"></i>
                    </span>
                  </div>
                  <h5 class="mb-1"><%= row.name %></h5>
                  <p class="text-muted mb-3"><%= row.description || 'No description' %></p>

                  <div class="d-flex justify-content-around border-top pt-3">
                    <div>
                      <div class="font-size-18 fw-bold"><%= row.permissionCount || (row.permissionCodes || []).length %></div>
                      <div class="text-muted small">permissions</div>
                    </div>
                    <div>
                      <div class="font-size-18 fw-bold"><%= row.userCount || (row.users || []).length %></div>
                      <div class="text-muted small">users</div>
                    </div>
                  </div>
                </div>
                <div class="card-footer d-flex gap-2">
                  <a href="/roles/<%= row.id %>/edit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bx bx-edit me-1"></i>Edit
                  </a>
                  <% if (!row.isBuiltin) { %>
                    <button type="button" class="btn btn-outline-danger btn-sm"
                            onclick="if (confirm('Delete this role? Users still mapped to it must be reassigned first.')) { var f = document.createElement('form'); f.method = 'POST'; f.action = '/roles/<%= row.id %>/delete'; document.body.appendChild(f); f.submit(); }">
                      <i class="bx bx-trash me-1"></i>Delete
                    </button>
                  <% } else { %>
                    <span class="btn btn-outline-secondary btn-sm disabled" title="Built-in roles cannot be removed">
                      <i class="bx bx-lock me-1"></i>Locked
                    </span>
                  <% } %>
                </div>
              </div>
            </div>

            <!-- Right column: permissions + users -->
            <div class="col-lg-8">
              <!-- Permissions by namespace -->
              <div class="card">
                <div class="card-body">
                  <h5 class="card-title mb-3"><i class="bx bx-key me-1"></i>Permissions</h5>
                  <% var granted = (row.permissionCodes || []); %>
                  <% if (granted.length === 0) { %>
                    <p class="text-muted mb-0">No permissions assigned.</p>
                  <% } else { %>
                    <div class="row g-2">
                      <% groups.forEach(function(g) { %>
                        <% var hasRead  = granted.indexOf(g.namespace + ':read')  !== -1; %>
                        <% var hasWrite = granted.indexOf(g.namespace + ':write') !== -1; %>
                        <div class="col-md-6">
                          <div class="border rounded p-3 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                              <strong><%= g.label %></strong>
                              <code class="text-muted small"><%= g.namespace %>:*</code>
                            </div>
                            <div class="d-flex gap-3">
                              <span class="badge bg-<%= hasRead ? 'success' : 'light text-dark' %>">
                                <i class="bx <%= hasRead ? 'bx-check' : 'bx-x' %> me-1"></i>Read
                              </span>
                              <span class="badge bg-<%= hasWrite ? 'primary' : 'light text-dark' %>">
                                <i class="bx <%= hasWrite ? 'bx-check' : 'bx-x' %> me-1"></i>Write
                              </span>
                            </div>
                          </div>
                        </div>
                      <% }); %>
                    </div>
                  <% } %>
                  <div class="alert alert-info mt-3 mb-0 small d-flex align-items-start">
                    <i class="bx bx-info-circle me-2 mt-1"></i>
                    <div>
                      The runtime permission gate reads the user's permission codes from
                      <code>req.session.userPermissions</code>, preloaded at login from the
                      <code>role_permissions</code> junction table. The 5 built-in roles
                      (IT Manager, IT Support, Department Head, Employee, Auditor) are seeded
                      with the same permission sets the legacy <code>PERMISSIONS</code> const
                      used, so a fresh seed gives every demo user the same access they had
                      before the migration. Custom roles created here take effect on the
                      next login.
                    </div>
                  </div>
                </div>
              </div>

              <!-- Users with this role -->
              <div class="card">
                <div class="card-body">
                  <h5 class="card-title mb-3"><i class="bx bx-user me-1"></i>Users with this role</h5>
                  <% if (!row.users || row.users.length === 0) { %>
                    <p class="text-muted mb-0">No users currently mapped to this role.</p>
                  <% } else { %>
                    <div class="table-responsive">
                      <table class="table table-sm table-nowrap align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Status</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% row.users.forEach(function(u) { %>
                            <tr>
                              <td><a href="/users/<%= u.id %>" class="text-reset"><strong><%= u.fullName %></strong></a></td>
                              <td><a href="mailto:<%= u.email %>" class="text-reset"><%= u.email %></a></td>
                              <td><span class="badge bg-<%= u.status === 'ACTIVE' ? 'success' : u.status === 'PENDING' ? 'warning' : 'secondary' %>"><%= u.status || 'ACTIVE' %></span></td>
                            </tr>
                          <% }); %>
                        </tbody>
                      </table>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
      <%- include('../../partials/footer') %>
    </div>
  </div>
  <%- include('../../partials/scripts', { pageScripts: [] }) %>
</body>
</html>
