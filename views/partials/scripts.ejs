    <!-- Right-bar (settings panel) — was missing from the project; included here so the gear icon in the topbar works. -->
    <%- include('../partials/rightbar') %>

    <!-- Right-bar init shim (vanilla JS, no jQuery — jQuery is reverted to the broken local ref). -->
    <script>
      (function () {
        function init() {
          // Gear icon / close button / overlay: toggle body.right-bar-enabled
          document.addEventListener('click', function (e) {
            var t = e.target.closest && e.target.closest('.right-bar-toggle');
            if (t) {
              e.preventDefault();
              document.body.classList.toggle('right-bar-enabled');
              return;
            }
            var overlay = e.target.closest && e.target.closest('.rightbar-overlay');
            if (overlay) {
              document.body.classList.remove('right-bar-enabled');
            }
          });

          // Layout Mode radios (Minia Theme Customizer) — wire up dark/light
          var layoutModeRadios = document.querySelectorAll('input[name="layout-mode"]');
          if (layoutModeRadios.length) {
            // Sync checked state on page load from the current dark-mode attribute
            var currentMode = document.body.getAttribute('data-layout-mode') === 'dark' ? 'dark' : 'light';
            layoutModeRadios.forEach(function (radio) {
              radio.checked = (radio.value === currentMode);
              radio.addEventListener('change', function () {
                if (!radio.checked) return;
                try {
                  if (radio.value === 'dark') {
                    document.body.setAttribute('data-layout-mode', 'dark');
                    document.documentElement.setAttribute('data-bs-theme', 'dark');
                    localStorage.setItem('data-layout-mode', 'dark');
                  } else {
                    document.body.removeAttribute('data-layout-mode');
                    document.documentElement.removeAttribute('data-bs-theme');
                    localStorage.setItem('data-layout-mode', 'light');
                  }
                } catch (e) { /* localStorage may be disabled */ }
              });
            });
          }
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>
