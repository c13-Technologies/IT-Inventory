    <!-- Clarity theme's master JS. Powers sidebar chevron collapse (metisMenu init on #side-menu), the right-bar settings panel (layout mode, layout width, sidebar size, topbar/sidebar color, layout direction), the vertical-menu button, fullscreen toggle, feather.replace(), Waves.init(), and tooltip/popover/toast auto-init. Served locally (zero CDN policy). -->
    <script src="assets/js/app.js"></script>

<% if (typeof pageScripts !== "undefined" && pageScripts && pageScripts.length) { %>
<% pageScripts.forEach(function (s) { %>
    <script src="<%= s %>"></script>
<% }); %>
<% } %>

    <!-- feather.replace() safety net — app.js already calls it, but this stays so sidebar icons still render if app.js ever fails to load. -->
    <script>if (window.feather) { feather.replace(); }</script>

    <!-- Right-bar (settings panel) — was missing from the project; included here so the gear icon in the topbar works. -->
    <%- include('../partials/rightbar') %>

    <!-- Dark-mode persistence spy: Clarity app.js toggles the visual theme but does not save the choice to localStorage, so a reload falls back to light. Mirror its decisions here so the choice survives a refresh (the FOUC shim in head.ejs then re-applies it on the next page load). -->
    <script>
      (function () {
        function init() {
          var KEY = 'data-layout-mode';
          var btn = document.getElementById('mode-setting-btn');
          if (btn) btn.addEventListener('click', function () {
            try {
              var isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
              localStorage.setItem(KEY, isDark ? 'light' : 'dark');
            } catch (e) { /* localStorage may be disabled */ }
          });
          document.addEventListener('change', function (e) {
            var t = e.target;
            if (t && t.name === 'layout-mode') {
              try { localStorage.setItem(KEY, t.value); } catch (err) { /* localStorage may be disabled */ }
            }
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>
