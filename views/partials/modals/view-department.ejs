<%# views/partials/modals/view-department.ejs
   Shared Bootstrap modal showing details of one department.
   Triggered from the /departments list via [data-bs-toggle="modal"]
   on the row's [View] button. Edit / Delete reuse the existing crud-modal
   and deleteModal helpers. Back just closes this modal.
   Locals: (none — uses window.__CRUD_ROWS__ populated by the list page)
%>
<div class="modal fade" id="viewDepartmentModal" tabindex="-1" aria-labelledby="viewDepartmentModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="viewDepartmentModalLabel">
          <i class="bx bx-buildings me-1"></i>Department details
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <dl class="row mb-0" id="viewDepartmentFields">
          <dt class="col-sm-4 text-muted fw-normal">Name</dt>
          <dd class="col-sm-8" data-field="name">&mdash;</dd>
          <dt class="col-sm-4 text-muted fw-normal">Code</dt>
          <dd class="col-sm-8" data-field="code">&mdash;</dd>
          <dt class="col-sm-4 text-muted fw-normal">Head</dt>
          <dd class="col-sm-8" data-field="head">&mdash;</dd>
          <dt class="col-sm-4 text-muted fw-normal">ID</dt>
          <dd class="col-sm-8"><code class="text-muted" data-field="id">&mdash;</code></dd>
        </dl>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">
          <i class="bx bx-arrow-back me-1"></i>Back
        </button>
        <button type="button" class="btn btn-outline-danger" id="viewDepartmentDeleteBtn">
          <i class="bx bx-trash me-1"></i>Delete
        </button>
        <a class="btn btn-primary disabled" id="viewDepartmentEditBtn" tabindex="-1" aria-disabled="true">
          <i class="bx bx-edit me-1"></i>Edit
        </a>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var modalEl  = document.getElementById('viewDepartmentModal');
  if (!modalEl) return;

  var titleEl  = document.getElementById('viewDepartmentModalLabel');
  var editBtn  = document.getElementById('viewDepartmentEditBtn');
  var delBtn   = document.getElementById('viewDepartmentDeleteBtn');
  var fieldEls = modalEl.querySelectorAll('[data-field]');

  function displayVal(v) {
    if (v == null || v === '') return '\u2014';
    return String(v).replace(/_/g, ' ');
  }

  // Resolve the head's display name from window.__CRUD_HEAD_MAP__ (set by
  // /departments list page when it rendered) so the modal shows the head's
  // actual full-name rather than a raw user id. Falls back to the raw id.
  function headDisplay(row) {
    if (!row.headId) return '\u2014';
    var map = window.__CRUD_HEAD_MAP__ || {};
    var u = map[row.headId];
    if (u && (u.fullName || u.name)) return u.fullName || u.name;
    return row.headId;
  }

  function populateDepartmentModal(row) {
    var name = (row.name || '').trim();
    if (titleEl) titleEl.textContent = name || 'Department details';

    var map = {
      name: row.name,
      code: row.code,
      head: headDisplay(row),
      id:   row.id,
    };
    fieldEls.forEach(function(el) {
      var key = el.dataset.field;
      el.textContent = displayVal(map[key]);
    });

    if (editBtn) {
      editBtn.href = '/departments/' + row.id + '/edit';
      editBtn.removeAttribute('aria-disabled');
      editBtn.removeAttribute('tabindex');
    }
    if (delBtn) {
      if (typeof window.openDeleteModal === 'function') {
        delBtn.style.display = '';
        delBtn.onclick = function() {
          var modalBs = bootstrap.Modal.getInstance(modalEl);
          if (modalBs) modalBs.hide();
          window.openDeleteModal('departments', row.id, 'department');
        };
      } else {
        delBtn.style.display = 'none';
      }
    }
  }

  modalEl.addEventListener('show.bs.modal', function(ev) {
    var btn = ev.relatedTarget;
    var id = btn && btn.dataset && btn.dataset.rowId;
    if (!id) return;
    var row = (window.__CRUD_ROWS__ || {})[id];
    if (!row) { console.warn('viewDepartmentModal: no row in __CRUD_ROWS__ for id', id); return; }
    populateDepartmentModal(row);
  });

  window.openViewDepartmentModal = function(rowId) {
    var row = (window.__CRUD_ROWS__ || {})[rowId];
    if (!row) { console.warn('openViewDepartmentModal: no row in __CRUD_ROWS__ for id', rowId); return; }
    populateDepartmentModal(row);
    var modalBs = bootstrap.Modal.getOrCreateInstance(modalEl);
    modalBs.show();
  };
});
</script>
