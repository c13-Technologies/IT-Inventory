<!-- Right Sidebar (settings panel) — opened by the gear icon (.right-bar-toggle) in the topbar. Closes via the X button, the overlay, or another toggle. -->
<div class="right-bar">
  <div class="right-bar-overlay"></div>
  <div class="right-bar-content">
    <div class="right-bar-header">
      <h5 class="right-bar-title">Settings</h5>
      <button type="button" class="right-bar-toggle right-bar-close" aria-label="Close settings panel">
        <i data-feather="x"></i>
      </button>
    </div>
    <div class="right-bar-body">
      <div class="right-bar-section">
        <h6 class="right-bar-section-title">Layout</h6>
        <div class="right-bar-option">
          <label class="right-bar-switch">
            <input type="checkbox" id="rightbar-dark-mode">
            <span class="right-bar-switch-label">Dark mode</span>
          </label>
        </div>
        <div class="right-bar-option">
          <label class="right-bar-switch">
            <input type="checkbox" id="rightbar-compact-sidebar">
            <span class="right-bar-switch-label">Compact sidebar</span>
          </label>
        </div>
      </div>
      <div class="right-bar-section">
        <h6 class="right-bar-section-title">About</h6>
        <p class="right-bar-note">IT Inventory UI — Phase 1. More customization options coming in Phase 2.</p>
      </div>
    </div>
  </div>
</div>
