<!doctype html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <base href="/">
    <!-- Dark/light mode FOUC prevention: app.js (the Minia theme's master JS) toggles the visual theme but does not persist the choice across reloads, so the small persistence spy in scripts.ejs writes it to localStorage and this block reads it back on the next request. Sets data-bs-theme synchronously in <head> BEFORE first paint on BOTH <html> (Bootstrap CSS selectors) AND <body> (Minia app.js's init branch logic reads from body, so it MUST be set to the saved value to avoid app.js silently flipping to dark when the saved choice is light). -->
    <script>
      (function () {
        try {
          var saved = localStorage.getItem('data-layout-mode');
          if (saved === 'dark') {
            document.documentElement.setAttribute('data-bs-theme', 'dark');
            document.body.setAttribute('data-bs-theme', 'dark');
          } else {
            // Explicitly set light on body so app.js's `body[data-bs-theme=dark]` branch picks the right init; noop visually because light is the default.
            document.body.setAttribute('data-bs-theme', 'light');
          }
        } catch (e) { /* localStorage may be disabled */ }
      })();
    </script>
    <title><%= title %> | Minia - Minimal Admin & Dashboard Template</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta content="Premium Multipurpose Admin & Dashboard Template" name="description" />
    <meta content="Themesbrand" name="author" />
    <!-- App favicon -->
    <link rel="shortcut icon" href="assets/images/favicon.ico">

    <!-- IBM Plex Sans (Minia's native font — copied from ref/assets/css/app.min.css @import; provides darker, more readable text vs the fallback sans-serif) -->
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">

    <!-- plugin css -->
    <link href="assets/libs/admin-resources/jquery.vectormap/jquery-jvectormap-1.2.2.css" rel="stylesheet" type="text/css" />

    <!-- preloader css -->
    <link rel="stylesheet" href="assets/css/preloader.min.css" type="text/css" />

    <!-- Bootstrap Css -->
    <link href="assets/css/bootstrap.min.css" id="bootstrap-style" rel="stylesheet" type="text/css" />
    <!-- Icons Css: bundles the @font-face declarations for Material Design Icons, Boxicons, and Font Awesome 5; served from assets/css/ with relative ../fonts/ paths. Replaces the previous boxicons/mdi/font-awesome CDN stylesheets (zero-CDN policy). -->
    <link href="assets/css/icons.min.css" rel="stylesheet" type="text/css" />
    <!-- App Css-->
    <link href="assets/css/app.min.css" id="app-style" rel="stylesheet" type="text/css" />

</head>