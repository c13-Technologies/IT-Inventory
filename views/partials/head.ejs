<!doctype html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <base href="/">
    <!-- Dark/light mode persistence: assets/js/app.js (the Minia theme's main JS, which handles the mode toggle + localStorage) is missing in this project, so the toggle never saves. This inline shim handles init + click. -->
    <script>
      (function () {
        try {
          var KEY = 'data-layout-mode';
          var saved = localStorage.getItem(KEY);
          // Set html data attr synchronously in <head> to avoid a flash of light mode (Bootstrap 5.3+).
          if (saved === 'dark') {
            document.documentElement.setAttribute('data-bs-theme', 'dark');
          }
          var apply = function () {
            if (localStorage.getItem(KEY) === 'dark') {
              document.body.setAttribute('data-layout-mode', 'dark');
            }
            var btn = document.getElementById('mode-setting-btn');
            if (!btn) return;
            btn.addEventListener('click', function () {
              var isDark = document.body.getAttribute('data-layout-mode') === 'dark';
              if (isDark) {
                document.body.removeAttribute('data-layout-mode');
                document.documentElement.removeAttribute('data-bs-theme');
                localStorage.setItem(KEY, 'light');
              } else {
                document.body.setAttribute('data-layout-mode', 'dark');
                document.documentElement.setAttribute('data-bs-theme', 'dark');
                localStorage.setItem(KEY, 'dark');
              }
            });
          };
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', apply);
          } else {
            apply();
          }
        } catch (e) { /* localStorage may be disabled */ }
      })();
    </script>
    <title><%= title %> | Minia - Minimal Admin & Dashboard Template</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta content="Premium Multipurpose Admin & Dashboard Template" name="description" />
    <meta content="Themesbrand" name="author" />
    <!-- App favicon -->
    <link rel="shortcut icon" href="assets/images/favicon.ico">
    <!-- Icon CSS — project ships only the woff2 font files; load each icon family's CSS from a CDN -->
    <!-- Boxicons: .bx bx-* classes (notification icons + action buttons) -->
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
    <!-- Material Design Icons: .mdi mdi-* classes (topbar clock/magnify/chevron/lock/logout/etc) -->
    <link href="https://cdn.jsdelivr.net/npm/@mdi/font@7.4.47/css/materialdesignicons.min.css" rel="stylesheet">
    <!-- Font Awesome 5 Free: .fa fa-* legacy + .fas fa-* solid classes (topbar hamburger) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

    <!-- Vectormap CSS (local file exists) -->
    <link href="assets/libs/admin-resources/jquery.vectormap/jquery-jvectormap-1.2.2.css" rel="stylesheet" type="text/css" />

    <!-- Framework CSS — project's local files are missing; load from CDN -->
    <!-- Bootstrap 5.3 CSS — required for layout, components, [data-bs-theme] dark mode -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <!-- Simplebar CSS — styled scrollbars for sidebar/topbar -->
    <link href="https://cdn.jsdelivr.net/npm/simplebar@5.3.6/dist/simplebar.min.css" rel="stylesheet" type="text/css" />
    <!-- Waves CSS — click ripple effect on .waves-effect buttons -->
    <link href="https://cdn.jsdelivr.net/npm/node-waves@0.7.6/dist/waves.min.css" rel="stylesheet" type="text/css" />
    <!-- Pace CSS — page-load progress bar (uses the black/minimal theme to match Minia's look) -->
    <link href="https://cdn.jsdelivr.net/npm/pace-js@1.2.4/themes/black/pace-theme-minimal.css" rel="stylesheet" type="text/css" />

</head>