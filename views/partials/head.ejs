<!doctype html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <base href="/">
    <!-- Dark/light mode persistence: assets/js/app.js (the Minia theme's main JS, which handles the mode toggle + localStorage) is missing in this project, so the toggle never saves. This inline shim handles init + click. -->
    <script>
      (function () {
        try {
          var KEY = 'data-layout-mode';
          var saved = localStorage.getItem(KEY);
          // Set html data attr synchronously in <head> to avoid a flash of light mode (Bootstrap 5.3+).
          if (saved === 'dark') {
            document.documentElement.setAttribute('data-bs-theme', 'dark');
          }
          var apply = function () {
            if (localStorage.getItem(KEY) === 'dark') {
              document.body.setAttribute('data-layout-mode', 'dark');
            }
            var btn = document.getElementById('mode-setting-btn');
            if (!btn) return;
            btn.addEventListener('click', function () {
              var isDark = document.body.getAttribute('data-layout-mode') === 'dark';
              if (isDark) {
                document.body.removeAttribute('data-layout-mode');
                document.documentElement.removeAttribute('data-bs-theme');
                localStorage.setItem(KEY, 'light');
              } else {
                document.body.setAttribute('data-layout-mode', 'dark');
                document.documentElement.setAttribute('data-bs-theme', 'dark');
                localStorage.setItem(KEY, 'dark');
              }
            });
          };
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', apply);
          } else {
            apply();
          }
        } catch (e) { /* localStorage may be disabled */ }
      })();
    </script>
    <title><%= title %> | Minia - Minimal Admin & Dashboard Template</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta content="Premium Multipurpose Admin & Dashboard Template" name="description" />
    <meta content="Themesbrand" name="author" />
    <!-- App favicon -->
    <link rel="shortcut icon" href="assets/images/favicon.ico">
    <!-- Icon CSS — project ships only the woff2 font files; load each icon family's CSS from a CDN -->
    <!-- Boxicons: .bx bx-* classes (notification icons + action buttons) -->
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
    <!-- Material Design Icons: .mdi mdi-* classes (topbar clock/magnify/chevron/lock/logout/etc) -->
    <link href="https://cdn.jsdelivr.net/npm/@mdi/font@7.4.47/css/materialdesignicons.min.css" rel="stylesheet">
    <!-- Font Awesome 5 Free: .fa fa-* legacy + .fas fa-* solid classes (topbar hamburger) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

    <!-- plugin css -->
    <link href="assets/libs/admin-resources/jquery.vectormap/jquery-jvectormap-1.2.2.css" rel="stylesheet" type="text/css" />

    <!-- preloader css -->
    <link rel="stylesheet" href="assets/css/preloader.min.css" type="text/css" />

    <!-- Bootstrap Css -->
    <link href="assets/css/bootstrap.min.css" id="bootstrap-style" rel="stylesheet" type="text/css" />
    <!-- Icons Css (loaded from CDN above; project's local assets/css/icons.min.css is missing) -->
    <!-- App Css-->
    <link href="assets/css/app.min.css" id="app-style" rel="stylesheet" type="text/css" />

    <!-- Right-bar (settings panel) styles — the Minia template's right-bar CSS lives in assets/css/app.min.css which is missing. Inline the minimum here so the gear icon works. -->
    <style>
      .right-bar {
        position: fixed;
        top: 0;
        right: 0;
        width: 320px;
        height: 100vh;
        z-index: 9999;
        pointer-events: none;
        transform: translateX(100%);
        transition: transform 0.3s ease-in-out;
        background: #fff;
        box-shadow: -2px 0 8px rgba(0, 0, 0, 0.1);
      }
      .right-bar-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease-in-out;
        z-index: 9998;
      }
      body.right-bar-enabled .right-bar {
        pointer-events: auto;
        transform: translateX(0);
      }
      body.right-bar-enabled .right-bar-overlay {
        opacity: 1;
        pointer-events: auto;
      }
      .right-bar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 18px;
        border-bottom: 1px solid #e5e7eb;
      }
      .right-bar-title { margin: 0; font-size: 16px; font-weight: 600; }
      .right-bar-close {
        background: none; border: none; cursor: pointer;
        color: #6b7280; padding: 4px; line-height: 1;
      }
      .right-bar-close:hover { color: #111827; }
      .right-bar-body { padding: 18px; max-height: calc(100vh - 56px); overflow-y: auto; }
      .right-bar-section { margin-bottom: 22px; }
      .right-bar-section-title {
        font-size: 11px; text-transform: uppercase; color: #6b7280;
        margin: 0 0 10px; font-weight: 600; letter-spacing: 0.5px;
      }
      .right-bar-option { margin-bottom: 10px; }
      .right-bar-switch { display: flex; align-items: center; gap: 8px; cursor: pointer; }
      .right-bar-switch-label { font-size: 14px; }
      .right-bar-note { font-size: 12px; color: #6b7280; margin: 0; line-height: 1.5; }
      /* Dark mode support via Bootstrap 5.3+ [data-bs-theme] */
      [data-bs-theme="dark"] .right-bar { background: #1f2937; color: #e5e7eb; }
      [data-bs-theme="dark"] .right-bar-header { border-bottom-color: #374151; }
      [data-bs-theme="dark"] .right-bar-section-title,
      [data-bs-theme="dark"] .right-bar-note { color: #9ca3af; }
      [data-bs-theme="dark"] .right-bar-close { color: #9ca3af; }
      [data-bs-theme="dark"] .right-bar-close:hover { color: #e5e7eb; }
      /* Compact sidebar */
      body.sidebar-compact .vertical-menu { width: 180px !important; }
      /* Mobile */
      @media (max-width: 768px) { .right-bar { width: 100%; } }
    </style>

</head>