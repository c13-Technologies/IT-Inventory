<!doctype html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <base href="/">
    <!-- Dark/light mode persistence: assets/js/app.js (the Minia theme's main JS, which handles the mode toggle + localStorage) is missing in this project, so the toggle never saves. This inline shim handles init + click. -->
    <script>
      (function () {
        try {
          var KEY = 'data-layout-mode';
          var saved = localStorage.getItem(KEY);
          // Set html data attr synchronously in <head> to avoid a flash of light mode (Bootstrap 5.3+).
          if (saved === 'dark') {
            document.documentElement.setAttribute('data-bs-theme', 'dark');
          }
          var apply = function () {
            if (localStorage.getItem(KEY) === 'dark') {
              document.body.setAttribute('data-layout-mode', 'dark');
            }
            var btn = document.getElementById('mode-setting-btn');
            if (!btn) return;
            btn.addEventListener('click', function () {
              var isDark = document.body.getAttribute('data-layout-mode') === 'dark';
              if (isDark) {
                document.body.removeAttribute('data-layout-mode');
                document.documentElement.removeAttribute('data-bs-theme');
                localStorage.setItem(KEY, 'light');
              } else {
                document.body.setAttribute('data-layout-mode', 'dark');
                document.documentElement.setAttribute('data-bs-theme', 'dark');
                localStorage.setItem(KEY, 'dark');
              }
            });
          };
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', apply);
          } else {
            apply();
          }
        } catch (e) { /* localStorage may be disabled */ }
      })();
    </script>
    <title><%= title %> | Minia - Minimal Admin & Dashboard Template</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta content="Premium Multipurpose Admin & Dashboard Template" name="description" />
    <meta content="Themesbrand" name="author" />
    <!-- App favicon -->
    <link rel="shortcut icon" href="assets/images/favicon.ico">
    <!-- Icon CSS — project ships only the woff2 font files; load each icon family's CSS from a CDN -->
    <!-- Boxicons: .bx bx-* classes (notification icons + action buttons) -->
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
    <!-- Material Design Icons: .mdi mdi-* classes (topbar clock/magnify/chevron/lock/logout/etc) -->
    <link href="https://cdn.jsdelivr.net/npm/@mdi/font@7.4.47/css/materialdesignicons.min.css" rel="stylesheet">
    <!-- Font Awesome 5 Free: .fa fa-* legacy + .fas fa-* solid classes (topbar hamburger) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

    <!-- plugin css -->
    <link href="assets/libs/admin-resources/jquery.vectormap/jquery-jvectormap-1.2.2.css" rel="stylesheet" type="text/css" />

    <!-- preloader css -->
    <link rel="stylesheet" href="assets/css/preloader.min.css" type="text/css" />

    <!-- Bootstrap Css -->
    <link href="assets/css/bootstrap.min.css" id="bootstrap-style" rel="stylesheet" type="text/css" />
    <!-- Icons Css (loaded from CDN above; project's local assets/css/icons.min.css is missing) -->
    <!-- App Css-->
    <link href="assets/css/app.min.css" id="app-style" rel="stylesheet" type="text/css" />

    <!-- Right-bar (Theme Customizer) styles — the Minia template's right-bar CSS lives in assets/css/app.min.css which is missing. Inline the minimum here so the gear icon works. Uses right: -320px (not transform) so the inner .rightbar-overlay stays viewport-relative. -->
    <style>
      .right-bar {
        position: fixed;
        top: 0;
        right: -320px;
        width: 320px;
        height: 100vh;
        z-index: 10000;
        background: #fff;
        box-shadow: -2px 0 8px rgba(0, 0, 0, 0.1);
        transition: right 0.3s ease-in-out;
        display: flex;
        flex-direction: column;
      }
      body.right-bar-enabled .right-bar { right: 0; }
      .rightbar-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.5);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease-in-out;
        z-index: 9999;
      }
      body.right-bar-enabled .rightbar-overlay { opacity: 1; pointer-events: auto; }
      /* Minia internal layout */
      .right-bar [data-simplebar] {
        overflow-y: auto;
        overflow-x: hidden;
        width: 100%;
        flex: 1;
      }
      .right-bar .rightbar-title {
        display: flex;
        align-items: center;
        padding: 12px 16px;
      }
      .right-bar .rightbar-title h5 {
        margin: 0 8px 0 0;
        font-size: 16px;
        font-weight: 600;
      }
      .right-bar .rightbar-title .right-bar-toggle {
        margin-left: auto;
        color: #6b7280;
        text-decoration: none;
        font-size: 20px;
        line-height: 1;
        cursor: pointer;
      }
      .right-bar .rightbar-title .right-bar-toggle:hover { color: #111827; }
      .right-bar hr { margin: 0; border: 0; border-top: 1px solid #e5e7eb; }
      .right-bar .p-4 { padding: 20px; }
      .right-bar h6 {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin: 0 0 12px;
      }
      .right-bar h6.mt-4 { margin-top: 20px; padding-top: 8px; }
      .right-bar .form-check {
        display: inline-block;
        margin-right: 16px;
        margin-bottom: 8px;
        padding-left: 0;
      }
      .right-bar .form-check-input {
        margin-right: 6px;
        cursor: pointer;
      }
      .right-bar .form-check-label {
        cursor: pointer;
        font-size: 14px;
      }
      /* Dark mode support via Bootstrap 5.3+ [data-bs-theme] */
      [data-bs-theme="dark"] .right-bar { background: #1f2937; color: #e5e7eb; }
      [data-bs-theme="dark"] .right-bar hr { border-top-color: #374151; }
      [data-bs-theme="dark"] .right-bar h6 { color: #e5e7eb; }
      [data-bs-theme="dark"] .right-bar .rightbar-title .right-bar-toggle { color: #9ca3af; }
      [data-bs-theme="dark"] .right-bar .rightbar-title .right-bar-toggle:hover { color: #e5e7eb; }
      /* Mobile */
      @media (max-width: 768px) {
        .right-bar { width: 100%; right: -100%; }
        body.right-bar-enabled .right-bar { right: 0; }
      }
    </style>

</head>